{"543z": ["\u041b\u0435\u043a. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430,\u043f\u0440\u043e\u0444. \u041f\u0440\u0443\u0446\u043a\u043e\u0432 \u0410.\u0412., \u0430\u0443\u0434. 346 C", "", "\u041b\u0435\u043a. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 465 C", "", "\u041b\u0435\u043a. \u0412\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0443\u044e \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c,\u0434\u043e\u0446. \u041a\u0440\u043e\u0448\u0438\u043b\u0438\u043d\u0430 \u0421.\u0412., \u0430\u0443\u0434. 267 C", "", "\u041b\u0435\u043a. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 302 C", "", "\u041b\u0435\u043a. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 465 C", "\u0423\u043f\u0440. \u042d\u043b\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0421\u043f\u043e\u0440\u0442\u0437\u0430\u043b C", "\u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u043f.\u0433. 1,\u0441\u0442. \u043f\u0440\u0435\u043f. \u041a\u043e\u043d\u044c\u043a\u043e\u0432\u0430 \u0414.\u041f., \u0430\u0443\u0434. 322 C \u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u043f.\u0433. 2,\u0434\u043e\u0446. \u0422\u0440\u0443\u0448\u043a\u043e\u0432\u0430 \u0418.\u041d., \u0430\u0443\u0434. 310 C", "", "\u041b\u0435\u043a. \u0412\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0443\u044e \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c,\u0434\u043e\u0446. \u041a\u0440\u043e\u0448\u0438\u043b\u0438\u043d\u0430 \u0421.\u0412., \u0430\u0443\u0434. 405 C", "", "\u0423\u043f\u0440. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 106\u0430 C", "\u041b\u0430\u0431. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435, \u043f.\u0433. 1,\u0430\u0441. \u0411\u0430\u043a\u043e\u043d\u0438\u043d \u0414.\u0412., \u0430\u0443\u0434. 206-3 C \u041b\u0430\u0431. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435, \u043f.\u0433. 2,\u0430\u0441. \u0410\u043d\u0442\u043e\u043d\u0443\u0448\u043a\u0438\u043d\u0430 \u0421.\u0414., \u0430\u0443\u0434. 206-3 C", "\u0423\u043f\u0440. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 442 C", "", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u041f\u044b\u043b\u044c\u043a\u0438\u043d \u0412.\u0410., \u0430\u0443\u0434. 463 C", "", "\u0423\u043f\u0440. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 437 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 1,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C \u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 2,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0418\u0432\u0430\u043d\u0435\u043d\u043a\u043e \u041b.\u0418., \u0430\u0443\u0434. 414 C", "", "", "", "", "", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 1,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C \u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 2,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0418\u0432\u0430\u043d\u0435\u043d\u043a\u043e \u041b.\u0418., \u0430\u0443\u0434. 414 C", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", ""], "543c": ["\u041b\u0435\u043a. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0437\u0430\u0432. \u043a\u0430\u0444. \u0421\u043e\u043a\u043e\u043b\u043e\u0432 \u0410.\u0421., \u0430\u0443\u0434. 448 C", "\u0423\u043f\u0440. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 407 C", "\u041b\u0435\u043a. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 405 C", "", "\u041b\u0435\u043a. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0437\u0430\u0432. \u043a\u0430\u0444. \u0421\u043e\u043a\u043e\u043b\u043e\u0432 \u0410.\u0421., \u0430\u0443\u0434. 337 C", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u041f\u044b\u043b\u044c\u043a\u0438\u043d \u0412.\u0410., \u0430\u0443\u0434. 407 C", "\u041b\u0435\u043a. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 302 C", "\u0423\u043f\u0440. \u042d\u043b\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0421\u043f\u043e\u0440\u0442\u0437\u0430\u043b C", "\u041b\u0435\u043a. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 405 C", "\u0423\u043f\u0440. \u042d\u043b\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0421\u043f\u043e\u0440\u0442\u0437\u0430\u043b C", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u041f\u044b\u043b\u044c\u043a\u0438\u043d \u0412.\u0410., \u0430\u0443\u0434. 407 C", "\u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u043f.\u0433. 1,\u0441\u0442. \u043f\u0440\u0435\u043f. \u041a\u043e\u043d\u044c\u043a\u043e\u0432\u0430 \u0414.\u041f., \u0430\u0443\u0434. 318 C \u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u043f.\u0433. 2,\u0434\u043e\u0446. \u0422\u0440\u0443\u0448\u043a\u043e\u0432\u0430 \u0418.\u041d., \u0430\u0443\u0434. 314 C", "\u0423\u043f\u0440. \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0420\u043e\u0441\u0441\u0438\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 403 C", "\u041b\u0435\u043a. \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0420\u043e\u0441\u0441\u0438\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 267 C", "\u041b\u0430\u0431. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430, \u043f.\u0433. 1,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0429\u0435\u043d\u0451\u0432\u0430 \u042e.\u0411., \u0430\u0443\u0434. 206-4 C \u041b\u0430\u0431. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430, \u043f.\u0433. 2,\u0434\u043e\u0446. \u0424\u0438\u043b\u0430\u0442\u043e\u0432 \u0418.\u042e., \u0430\u0443\u0434. 206-4 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 1,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C \u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 2,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0418\u0432\u0430\u043d\u0435\u043d\u043a\u043e \u041b.\u0418., \u0430\u0443\u0434. 414 C", "\u0423\u043f\u0440. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 441 C", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u041f\u044b\u043b\u044c\u043a\u0438\u043d \u0412.\u0410., \u0430\u0443\u0434. 437 C", "", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u041f\u044b\u043b\u044c\u043a\u0438\u043d \u0412.\u0410., \u0430\u0443\u0434. 457 C", "\u0423\u043f\u0440. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 206-2 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 1,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C \u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 2,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0418\u0432\u0430\u043d\u0435\u043d\u043a\u043e \u041b.\u0418., \u0430\u0443\u0434. 414 C", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "\u041b\u0435\u043a. \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0420\u043e\u0441\u0441\u0438\u0438 (\u0421\u0414\u041e)", "", "", "", "", "", "", "", "", "", ""], "5413z": ["\u041b\u0435\u043a. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430,\u043f\u0440\u043e\u0444. \u041f\u0440\u0443\u0446\u043a\u043e\u0432 \u0410.\u0412., \u0430\u0443\u0434. 346 C", "", "\u041b\u0435\u043a. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 465 C", "\u0423\u043f\u0440. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 444 C", "\u041b\u0435\u043a. \u0412\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0443\u044e \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c,\u0434\u043e\u0446. \u041a\u0440\u043e\u0448\u0438\u043b\u0438\u043d\u0430 \u0421.\u0412., \u0430\u0443\u0434. 267 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 1,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C \u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 2,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0418\u0432\u0430\u043d\u0435\u043d\u043a\u043e \u041b.\u0418., \u0430\u0443\u0434. 414 C", "\u041b\u0435\u043a. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 302 C", "", "\u041b\u0435\u043a. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 465 C", "\u0423\u043f\u0440. \u042d\u043b\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0421\u043f\u043e\u0440\u0442\u0437\u0430\u043b C", "\u041b\u0430\u0431. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435, \u043f.\u0433. 1,\u0430\u0441. \u0411\u0430\u043a\u043e\u043d\u0438\u043d \u0414.\u0412., \u0430\u0443\u0434. 206-3 C \u041b\u0430\u0431. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435, \u043f.\u0433. 2,\u0430\u0441. \u0410\u043d\u0442\u043e\u043d\u0443\u0448\u043a\u0438\u043d\u0430 \u0421.\u0414., \u0430\u0443\u0434. 206-3 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 1,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C \u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430, \u043f.\u0433. 2,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0418\u0432\u0430\u043d\u0435\u043d\u043a\u043e \u041b.\u0418., \u0430\u0443\u0434. 414 C", "\u041b\u0435\u043a. \u0412\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0443\u044e \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c,\u0434\u043e\u0446. \u041a\u0440\u043e\u0448\u0438\u043b\u0438\u043d\u0430 \u0421.\u0412., \u0430\u0443\u0434. 405 C", "", "\u0423\u043f\u0440. \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0420\u043e\u0441\u0441\u0438\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 442 C", "", "\u0423\u043f\u0440. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 206-4 C", "", "\u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u043f.\u0433. 1,\u0434\u043e\u0446. \u0418\u043d\u042f\u0437 \u0413\u0430\u043b\u0438\u0446\u044b\u043d\u0430 \u0418.\u0412., \u0430\u0443\u0434. 322 C \u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u043f.\u0433. 2,\u0441\u0442. \u043f\u0440\u0435\u043f. \u041a\u043e\u043d\u044c\u043a\u043e\u0432\u0430 \u0414.\u041f., \u0430\u0443\u0434. 316 C", "", "\u041b\u0430\u0431. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430, \u043f.\u0433. 1,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0429\u0435\u043d\u0451\u0432\u0430 \u042e.\u0411., \u0430\u0443\u0434. 206-4 C \u041b\u0430\u0431. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430, \u043f.\u0433. 2,\u0434\u043e\u0446. \u0424\u0438\u043b\u0430\u0442\u043e\u0432 \u0418.\u042e., \u0430\u0443\u0434. 206-4 C", "", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 450 C", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", ""], "5423c": ["\u041b\u0435\u043a. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0437\u0430\u0432. \u043a\u0430\u0444. \u0421\u043e\u043a\u043e\u043b\u043e\u0432 \u0410.\u0421., \u0430\u0443\u0434. 448 C", "", "\u041b\u0435\u043a. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 405 C", "", "\u041b\u0435\u043a. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0437\u0430\u0432. \u043a\u0430\u0444. \u0421\u043e\u043a\u043e\u043b\u043e\u0432 \u0410.\u0421., \u0430\u0443\u0434. 337 C", "", "\u041b\u0435\u043a. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 302 C", "\u0423\u043f\u0440. \u042d\u043b\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0421\u043f\u043e\u0440\u0442\u0437\u0430\u043b C", "\u041b\u0435\u043a. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 405 C", "\u0423\u043f\u0440. \u042d\u043b\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0421\u043f\u043e\u0440\u0442\u0437\u0430\u043b C", "\u0423\u043f\u0440. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 402 C", "", "", "\u041b\u0435\u043a. \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0420\u043e\u0441\u0441\u0438\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 267 C", "\u041b\u0430\u0431. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0430\u0441. \u041c\u043e\u0438\u0441\u0435\u0435\u0432 \u0410.\u0412., \u0430\u0443\u0434. 206-3 C", "\u0423\u043f\u0440. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 110 C", "\u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a,\u0434\u043e\u0446. \u0418\u043d\u042f\u0437 \u0413\u0430\u043b\u0438\u0446\u044b\u043d\u0430 \u0418.\u0412., \u0430\u0443\u0434. 322 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C", "", "", "\u041b\u0430\u0431. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430,\u0441\u0442. \u043f\u0440\u0435\u043f. \u0429\u0435\u043d\u0451\u0432\u0430 \u042e.\u0411., \u0430\u0443\u0434. 106\u0430 C", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 450 C", "\u0423\u043f\u0440. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 402 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C", "", "", "", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 450 C", "", "", "", "", "", "", "", "", "", "\u041b\u0435\u043a. \u0418\u0441\u0442\u043e\u0440\u0438\u044f \u0420\u043e\u0441\u0441\u0438\u0438 (\u0421\u0414\u041e)", "", "", "", "", "", "", "", "", "", ""], "5423z": ["\u041b\u0435\u043a. \u0422\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u043a\u0430,\u043f\u0440\u043e\u0444. \u041f\u0440\u0443\u0446\u043a\u043e\u0432 \u0410.\u0412., \u0430\u0443\u0434. 346 C", "", "\u041b\u0435\u043a. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 465 C", "", "\u041b\u0435\u043a. \u0412\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0443\u044e \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c,\u0434\u043e\u0446. \u041a\u0440\u043e\u0448\u0438\u043b\u0438\u043d\u0430 \u0421.\u0412., \u0430\u0443\u0434. 267 C", "", "\u041b\u0435\u043a. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 302 C", "", "\u041b\u0435\u043a. \u0410\u043d\u0430\u043b\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u044f,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 465 C", "\u0423\u043f\u0440. \u042d\u043b\u0435\u043a\u0442\u0438\u0432\u043d\u044b\u0435 \u0434\u0438\u0441\u0446\u0438\u043f\u043b\u0438\u043d\u044b \u043f\u043e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u0435 \u0438 \u0441\u043f\u043e\u0440\u0442\u0443, \u0421\u043f\u043e\u0440\u0442\u0437\u0430\u043b C", "\u0423\u043f\u0440. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 402 C", "", "\u041b\u0435\u043a. \u0412\u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u0432 \u043f\u0440\u043e\u0444\u0435\u0441\u0441\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0443\u044e \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c,\u0434\u043e\u0446. \u041a\u0440\u043e\u0448\u0438\u043b\u0438\u043d\u0430 \u0421.\u0412., \u0430\u0443\u0434. 405 C", "", "\u0423\u043f\u0440. \u041c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0430\u043d\u0430\u043b\u0438\u0437,\u0434\u043e\u0446. \u0426\u0438\u043f\u043e\u0440\u043a\u043e\u0432\u0430 \u041a.\u0410., \u0430\u0443\u0434. 437 C", "\u0423\u043f\u0440. \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435,\u0434\u043e\u0446. \u0414\u043c\u0438\u0442\u0440\u0438\u0435\u0432\u0430 \u0422.\u0410., \u0430\u0443\u0434. 106\u0430 C", "\u0423\u043f\u0440. \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a, \u0418\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0439 \u044f\u0437\u044b\u043a,\u0434\u043e\u0446. \u0418\u043d\u042f\u0437 \u0413\u0430\u043b\u0438\u0446\u044b\u043d\u0430 \u0418.\u0412., \u0430\u0443\u0434. 322 C", "\u041b\u0430\u0431. \u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430\u044f \u0433\u0440\u0430\u0444\u0438\u043a\u0430,\u0437\u0430\u0432. \u043a\u0430\u0444. \u041d\u0430\u0443\u043c\u043e\u0432 \u0414.\u0410., \u0430\u0443\u0434. 414 C", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 450 C", "", "", "\u0423\u043f\u0440. \u041e\u0441\u043d\u043e\u0432\u044b \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u0438,\u0434\u043e\u0446. \u0429\u0435\u0432\u044c\u0451\u0432 \u0410.\u0410., \u0430\u0443\u0434. 450 C", "\u0423\u043f\u0440. \u0410\u043d\u0430\u043b\u0438\u0442\u0